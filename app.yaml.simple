# DigitalOcean App Platform - Quick Start Configuration
# For deploying just Backend + Dashboard to DigitalOcean

name: tangentcloud-saas
services:
- name: api
  github:
    repo: kamaraj/kyrochatbot
    branch: tcsaasbot
  source_dir: backend
  build_command: pip install -r requirements.txt
  http_port: 8000
  run_command: uvicorn app.main:app --host 0.0.0.0 --port 8000
  envs:
  - key: OPENAI_API_KEY
    scope: RUN_AND_BUILD_TIME
    value: ${OPENAI_API_KEY}
  - key: LLM_PROVIDER
    scope: RUN_AND_BUILD_TIME
    value: openai
  - key: QDRANT_PATH
    scope: RUN_AND_BUILD_TIME
    value: /app/qdrant_db
  health_check:
    http_path: /health

- name: web
  github:
    repo: kamaraj/kyrochatbot
    branch: tcsaasbot
  source_dir: dashboard
  build_command: npm ci && npm run build
  http_port: 3000
  run_command: npm run start
  envs:
  - key: NEXT_PUBLIC_API_URL
    scope: RUN_AND_BUILD_TIME
    value: /api
  - key: NODE_ENV
    scope: RUN_AND_BUILD_TIME
    value: production
  health_check:
    http_path: /

databases:
- name: db
  engine: PG
  version: "15"
  production: true
  
- name: redis
  engine: REDIS
  version: "7"
  production: true

ingress:
  rules:
  - match:
      domain: ${APP_DOMAIN}
      path:
        prefix: /api
    component:
      name: api
  - match:
      domain: ${APP_DOMAIN}
    component:
      name: web
